{
  "crons": [
    { "path": "/api/sync/run", "schedule": "0 3 * * *" }
  ],
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/sync/*.js": { "maxDuration": 30 },
    "api/profile/build.js": { "maxDuration": 60 },
    "api/billing/*.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Request-Id", "value": "{requestId}" }
      ]
    }
  ]
}
